[
    {
        "id": "openclaw",
        "name": "OpenClaw",
        "version": "2.0.0",
        "description": "The flagship open-source, Node.js-based self-hosted agent that connects to messaging apps and executes tasks locally via your machine.",
        "github_url": "https://github.com/TheSandemon/OpenClaw",
        "support_url": "https://github.com/TheSandemon/OpenClaw",
        "license": "MIT",
        "icon": "🦞",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "npm install"
            ]
        },
        "execution": {
            "working_dir": "./agents/openclaw",
            "command": "node index.js",
            "env_vars_required": [
                "ANTHROPIC_API_KEY"
            ]
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ]
    },
    {
        "id": "memu-bot",
        "name": "memU Bot",
        "version": "1.0.0",
        "description": "An autonomous daemon specifically focused on proactive memory management and long-term context building.",
        "github_url": "https://github.com/TheSandemon/memU-Bot",
        "support_url": "https://github.com/TheSandemon/memU-Bot",
        "license": "MIT",
        "icon": "🧠",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "pip install -r requirements.txt"
            ]
        },
        "execution": {
            "working_dir": "./agents/memu-bot",
            "command": "python daemon.py",
            "env_vars_required": [
                "OPENAI_API_KEY"
            ]
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ]
    },
    {
        "id": "picoclaw",
        "name": "PicoClaw",
        "version": "1.0.0",
        "description": "An ultra-lightweight, Go-based agent built for $10 embedded hardware (RISC-V/ARM) with a sub-10MB RAM footprint and lightning-fast boot time.",
        "github_url": "https://github.com/TheSandemon/PicoClaw",
        "support_url": "https://github.com/TheSandemon/PicoClaw",
        "license": "MIT",
        "icon": "🦀",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "go build -o picoclaw main.go"
            ]
        },
        "execution": {
            "working_dir": "./agents/picoclaw",
            "command": "./picoclaw",
            "env_vars_required": [
                "GOOGLE_API_KEY"
            ]
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ]
    },
    {
        "id": "nanoclaw",
        "name": "NanoClaw",
        "version": "1.0.0",
        "description": "A containerized, security-first alternative built heavily around Anthropic's Agents SDK to prevent dangerous system access.",
        "github_url": "https://github.com/TheSandemon/NanoClaw",
        "support_url": "https://github.com/TheSandemon/NanoClaw",
        "license": "MIT",
        "icon": "🛡️",
