[
    {
        "id": "openclaw-core",
        "name": "OpenClaw",
        "version": "1.2.0",
        "description": "Autonomous coding agent powered by Claude. Reads repo context, writes code, creates PRs.",
        "github_url": "https://github.com/TheSandemon/OpenClaw",
        "support_url": "https://github.com/TheSandemon/OpenClaw",
        "license": "MIT",
        "icon": "🦞",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "npm install"
            ]
        },
        "execution": {
            "working_dir": "./agents/openclaw-core",
            "command": "node index.js",
            "env_vars_required": [
                "ANTHROPIC_API_KEY"
            ]
        }
    },
    {
        "id": "picoclaw",
        "name": "PicoClaw",
        "version": "0.8.0",
        "description": "Lightweight, compiled task runner for rapid-fire operations. Low memory footprint.",
        "github_url": "https://github.com/TheSandemon/PicoClaw",
        "support_url": "https://github.com/TheSandemon/PicoClaw",
        "license": "MIT",
        "icon": "🦀",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "cargo build --release"
            ]
        },
        "execution": {
            "working_dir": "./agents/picoclaw",
            "command": "./target/release/picoclaw",
            "env_vars_required": []
        }
    },
    {
        "id": "gemini-cli-agent",
        "name": "Gemini CLI",
        "version": "2.1.0",
        "description": "Google's Gemini-powered CLI agent. Multi-modal reasoning with code generation.",
        "github_url": "https://github.com/google-gemini/gemini-cli",
        "support_url": "https://github.com/google-gemini/gemini-cli",
        "license": "Apache-2.0",
        "icon": "💎",
        "installation": {
            "method": "npm_global",
            "setup_commands": [
                "npm install -g @google/gemini-cli"
            ]
        },
        "execution": {
            "working_dir": ".",
            "command": "gemini",
            "env_vars_required": [
                "GOOGLE_API_KEY"
            ]
        }
    },
    {
        "id": "claude-code-agent",
        "name": "Claude Code",
        "version": "1.0.0",
        "description": "Anthropic's agentic coding tool. Terminal-native with full project context.",
        "github_url": "https://github.com/anthropics/claude-code",
        "support_url": "https://github.com/anthropics/claude-code",
        "license": "Apache-2.0",
        "icon": "🧠",
        "installation": {
            "method": "npm_global",
            "setup_commands": [
                "npm install -g @anthropic-ai/claude-code"
            ]
        },
        "execution": {
            "working_dir": ".",
            "command": "claude",
            "env_vars_required": [
                "ANTHROPIC_API_KEY"
            ]
        }
    },
    {
        "id": "codex-agent",
        "name": "OpenAI Codex CLI",
        "version": "0.9.0",
        "description": "OpenAI's lightweight coding agent. Runs in your terminal with sandboxed execution.",
        "github_url": "https://github.com/openai/codex",
        "support_url": "https://github.com/openai/codex",
        "license": "Apache-2.0",
        "icon": "🤖",
        "installation": {
            "method": "npm_global",
            "setup_commands": [
                "npm install -g @openai/codex"
            ]
        },
        "execution": {
            "working_dir": ".",
            "command": "codex",
            "env_vars_required": [
                "OPENAI_API_KEY"
            ]
        }
    }
]