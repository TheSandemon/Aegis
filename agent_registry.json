            "method": "git_clone",
            "setup_commands": [
                "pip install anthropic"
            ]
        },
        "execution": {
            "working_dir": "./agents/nanoclaw",
            "command": "python nanoclaw.py",
            "env_vars_required": [
                "ANTHROPIC_API_KEY"
            ]
        },
        "permissions": [
            "read_file"
        ]
    },
