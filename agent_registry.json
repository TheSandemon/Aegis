[
    {
        "id": "aegis-orchestrator",
        "name": "Aegis Orchestrator",
        "version": "1.0.0",
        "description": "The required main orchestrator bot. Acts as a solo worker or a task-delegating manager for other bots. A fast, cost-effective model (e.g. GPT-4o-mini, Haiku) is recommended.",
        "github_url": "",
        "support_url": "",
        "license": "MIT",
        "icon": "\ud83d\udc51",
        "installation": {
            "method": "local",
            "setup_commands": []
        },
        "execution": {
            "working_dir": "./agents/aegis-orchestrator",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ],
        "is_orchestrator": true,
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are the Aegis Orchestrator. Manage and delegate tasks efficiently."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 2,
                "step": 0.1,
                "default": 0.3
            },
            "work_dir": {
                "type": "text",
                "label": "Workspace Path",
                "default": "./"
            },
            "pulse_interval": {
                "type": "number",
                "label": "Pulse Interval (Seconds)",
                "default": 30
            }
        }
    },
    {
        "id": "openclaw",
