[
    {
        "id": "aegis-worker",
        "name": "Aegis Worker",
        "version": "1.0.0",
        "description": "Standard autonomous worker. Thinking and Acting via LLM.",
        "icon": "\ud83e\udd16",
        "installation": {
            "method": "mock_local",
            "setup_commands": []
        },
        "execution": {
            "working_dir": "./agents/aegis-worker",
            "command": "python -u worker.py",
            "env_vars_required": []
        },
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "Process tasks and help the team."
            },
            "pulse_interval": {
                "type": "number",
                "label": "Pulse Interval (Seconds)",
                "default": 60
            },
            "work_dir": {
                "type": "folder",
                "label": "Workspace Path",
                "default": "./"
            },
            "startup_delay": {
                "type": "boolean",
                "label": "Delay First Action",
                "default": false,
                "description": "Wait one pulse interval before taking the first action."
            },
            "api_base_url": {
                "type": "text",
                "label": "Custom API Base URL (Optional)",
                "default": "",
                "description": "Override the default LLM API endpoint."
            },
            "character_type": {
                "type": "select",
                "label": "Character",
                "default": "robot",
                "options": [
                    {
                        "value": "robot",
                        "label": "\ud83e\udd16 Robot"
                    },
                    {
                        "value": "cat",
                        "label": "\ud83d\udc31 Cat"
                    },
                    {
                        "value": "dog",
                        "label": "\ud83d\udc36 Dog"
                    },
                    {
                        "value": "bear",
                        "label": "\ud83d\udc3b Bear"
                    },
                    {
                        "value": "bunny",
                        "label": "\ud83d\udc30 Bunny"
                    },
                    {
                        "value": "fox",
                        "label": "\ud83e\udd8a Fox"
                    },
                    {
                        "value": "owl",
                        "label": "\ud83e\udd89 Owl"
                    },
                    {
                        "value": "penguin",
                        "label": "\ud83d\udc27 Penguin"
                    }
                ]
            }
        }
    },
    {
        "id": "claude-code",
        "name": "Claude Code",
        "version": "1.0.0",
        "description": "Anthropic's agentic coding CLI. Requires an Anthropic API key and Node.js 18+.",
        "icon": "\ud83d\udfe0",
        "cli_agent": true,
        "api_key_env": "ANTHROPIC_API_KEY",
        "installation": {
            "method": "npm_global",
            "setup_commands": [
                "npm install -g @anthropic-ai/claude-code"
            ]
        },
        "execution": {
            "working_dir": "./agents/claude-code",
            "command": "python -u worker.py",
            "env_vars_required": []
        },
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "Process tasks from the Aegis board and help the team."
            },
            "pulse_interval": {
                "type": "number",
                "label": "Pulse Interval (Seconds)",
                "default": 120,
                "description": "How often to send a board-state update into the CLI agent's terminal. This is the autonomous heartbeat."
            },
            "work_dir": {
                "type": "folder",
                "label": "Workspace Path",
                "default": "./"
            },
            "startup_delay": {
                "type": "boolean",
                "label": "Delay First Action",
                "default": false,
                "description": "Wait one pulse interval before sending the initial prompt."
            },
            "api_base_url": {
                "type": "text",
                "label": "Custom API Base URL (Optional)",
                "default": "",
                "description": "Override the default Anthropic API endpoint to use custom providers like Minimax."
            },
            "character_type": {
                "type": "select",
                "label": "Character",
                "default": "robot",
                "options": [
                    {
                        "value": "robot",
                        "label": "\ud83e\udd16 Robot"
                    },
                    {
