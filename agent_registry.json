[
    {
        "id": "openclaw",
        "name": "OpenClaw",
        "version": "2.0.0",
        "description": "The flagship open-source, Node.js-based self-hosted agent that connects to messaging apps and executes tasks locally via your machine.",
        "github_url": "https://github.com/TheSandemon/OpenClaw",
        "support_url": "https://github.com/TheSandemon/OpenClaw",
        "license": "MIT",
        "icon": "\ud83e\udd9e",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "npm install"
            ]
        },
        "execution": {
            "working_dir": "./agents/openclaw",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ],
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are OpenClaw, an autonomous coding agent. Read the task, analyze the repo, write clean code, and create PRs."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 2,
                "step": 0.1,
                "default": 0.7
            },
            "max_tokens": {
                "type": "number",
                "label": "Max Tokens",
                "default": 8192
            },
            "tools_enabled": {
                "type": "multiselect",
                "label": "Allowed Tools",
                "options": [
                    "file_read",
                    "file_write",
                    "web_search",
                    "shell_exec",
                    "git_operations"
                ],
                "default": [
                    "file_read",
                    "file_write",
                    "git_operations"
                ]
            }
        }
    },
    {
        "id": "memu-bot",
        "name": "memU Bot",
        "version": "1.0.0",
        "description": "An autonomous daemon specifically focused on proactive memory management and long-term context building.",
        "github_url": "https://github.com/TheSandemon/memU-Bot",
        "support_url": "https://github.com/TheSandemon/memU-Bot",
        "license": "MIT",
        "icon": "\ud83e\udde0",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "pip install -r requirements.txt"
            ]
        },
        "execution": {
            "working_dir": "./agents/memu-bot",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ],
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are memU, a proactive memory agent. Continuously monitor conversations, extract key facts, and build a structured long-term knowledge graph."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 1,
                "step": 0.05,
                "default": 0.3
            },
            "memory_window": {
                "type": "number",
                "label": "Memory Window (messages)",
                "default": 500
            },
            "consolidation_interval": {
                "type": "number",
                "label": "Consolidation Interval (sec)",
                "default": 300
            }
        }
    },
    {
        "id": "picoclaw",
        "name": "PicoClaw",
        "version": "1.0.0",
        "description": "An ultra-lightweight, Go-based agent built for $10 embedded hardware (RISC-V/ARM) with a sub-10MB RAM footprint and lightning-fast boot time.",
        "github_url": "https://github.com/TheSandemon/PicoClaw",
        "support_url": "https://github.com/TheSandemon/PicoClaw",
        "license": "MIT",
        "icon": "\ud83e\udd80",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "go build -o picoclaw main.go"
            ]
        },
        "execution": {
            "working_dir": "./agents/picoclaw",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file",
            "write_file",
            "list_dir"
        ],
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are PicoClaw, a lean task executor. Complete tasks with minimal resource usage."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 1,
                "step": 0.1,
                "default": 0.5
            },
            "max_tokens": {
                "type": "number",
                "label": "Max Tokens",
                "default": 2048
            }
        }
    },
    {
        "id": "nanoclaw",
        "name": "NanoClaw",
        "version": "1.0.0",
        "description": "A containerized, security-first alternative built heavily around Anthropic's Agents SDK to prevent dangerous system access.",
        "github_url": "https://github.com/TheSandemon/NanoClaw",
        "support_url": "https://github.com/TheSandemon/NanoClaw",
        "license": "MIT",
        "icon": "\ud83d\udee1\ufe0f",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "pip install anthropic"
            ]
        },
        "execution": {
            "working_dir": "./agents/nanoclaw",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file"
        ],
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are NanoClaw, a security-first agent. All actions must be safe and verifiable. Never execute destructive operations."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 1,
                "step": 0.1,
                "default": 0.4
            },
            "max_tokens": {
                "type": "number",
                "label": "Max Tokens",
                "default": 4096
            },
            "sandbox_mode": {
                "type": "select",
                "label": "Sandbox Mode",
                "options": [
                    "strict",
                    "permissive",
                    "off"
                ],
                "default": "strict"
            }
        }
    },
    {
        "id": "trustclaw",
        "name": "TrustClaw",
        "version": "1.0.0",
        "description": "A hardened agent optimized specifically for verifiable execution and secure cloud/API interactions.",
        "github_url": "https://github.com/TheSandemon/TrustClaw",
        "support_url": "https://github.com/TheSandemon/TrustClaw",
        "license": "MIT",
        "icon": "\ud83d\udd10",
        "installation": {
            "method": "git_clone",
            "setup_commands": [
                "npm install",
                "npm run build"
            ]
        },
        "execution": {
            "working_dir": "./agents/trustclaw",
            "command": "python worker.py",
            "env_vars_required": []
        },
        "permissions": [
            "read_file",
            "list_dir"
        ],
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "You are TrustClaw, an execution verifier. Confirm all outputs are correct and audit all API calls for safety."
            },
            "temperature": {
                "type": "range",
                "label": "Creativity",
                "min": 0,
                "max": 1,
                "step": 0.1,
                "default": 0.2
            },
            "max_tokens": {
                "type": "number",
                "label": "Max Tokens",
                "default": 4096
            },
            "verify_outputs": {
                "type": "select",
                "label": "Output Verification",
                "options": [
                    "always",
                    "on_error",
                    "never"
                ],
                "default": "always"
            }
        }
    },
