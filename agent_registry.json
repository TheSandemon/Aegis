[
    {
        "id": "aegis-worker",
        "name": "Aegis Worker",
        "version": "1.0.0",
        "description": "Standard autonomous worker. Thinking and Acting via LLM.",
        "icon": "\ud83e\udd16",
        "installation": {
            "method": "mock_local",
            "setup_commands": []
        },
        "execution": {
            "working_dir": "./agents/aegis-worker",
            "command": "python -u worker.py",
            "env_vars_required": []
        },
        "config_schema": {
            "goals": {
                "type": "textarea",
                "label": "Agent Goals",
                "default": "Process tasks and help the team."
            },
            "mode": {
                "type": "select",
                "label": "Execution Mode",
                "options": [
                    "continuous",
                    "one-shot"
                ],
                "default": "continuous",
                "description": "Continuous: loops indefinitely each pulse. One-shot: runs once then exits."
            },
            "pulse_interval": {
                "type": "number",
                "label": "Pulse Interval (Seconds)",
                "default": 60
            },
            "work_dir": {
                "type": "text",
                "label": "Workspace Path (Local or URL)",
                "default": "./"
            },
            "startup_delay": {
                "type": "boolean",
                "label": "Delay First Action",
                "default": false,
                "description": "Wait one pulse interval before taking the first action."
            }
        }
    }
]