                    },
                    {
                        "value": "fox",
                        "label": "\ud83e\udd8a Fox"
                    },
                    {
                        "value": "owl",
                        "label": "\ud83e\udd89 Owl"
                    },
                    {
                        "value": "penguin",
                        "label": "\ud83d\udc27 Penguin"
                    }
                ]
            }
        }
    },
